/*
  Question 41 - Smart Home Air Quality Monitor
  Summer School IoT Assignment

  This project monitors smoke, temperature and humidity.
  It alerts the user using RGB LEDs, buzzer and Bluetooth.
*/

#include <DHT.h>
#include "BluetoothSerial.h"

BluetoothSerial SerialBT;

// ---------------- Pin Definitions ----------------

#define MQ2_PIN 34

#define DHTPIN 4
#define DHTTYPE DHT11

#define GREEN_LED 18
#define YELLOW_LED 19
#define RED_LED 21

#define BUZZER 23

DHT dht(DHTPIN, DHTTYPE);

// ---------------- Thresholds ----------------

const int SAFE_LIMIT = 300;
const int MODERATE_LIMIT = 600;

// ---------------- Setup ----------------

void setup() {

  Serial.begin(115200);

  SerialBT.begin("ESP32_AirMonitor");

  dht.begin();

  pinMode(GREEN_LED, OUTPUT);
  pinMode(YELLOW_LED, OUTPUT);
  pinMode(RED_LED, OUTPUT);

  pinMode(BUZZER, OUTPUT);

  Serial.println("Timestamp,MQ2,Temperature,Humidity,Status");
}

// ---------------- Main Loop ----------------

void loop() {

  int gasValue = analogRead(MQ2_PIN);

  float temperature = dht.readTemperature();

  float humidity = dht.readHumidity();

  String status = "";

  // Turn everything OFF before checking the level

  digitalWrite(GREEN_LED, LOW);
  digitalWrite(YELLOW_LED, LOW);
  digitalWrite(RED_LED, LOW);

  noTone(BUZZER);

  // ---------- SAFE ----------

  if (gasValue < SAFE_LIMIT) {

    status = "SAFE";

    digitalWrite(GREEN_LED, HIGH);

    SerialBT.println("SAFE");
    SerialBT.print("Gas : ");
    SerialBT.println(gasValue);
    SerialBT.print("Temp : ");
    SerialBT.println(temperature);
    SerialBT.print("Humidity : ");
    SerialBT.println(humidity);

  }

  // ---------- MODERATE ----------

  else if (gasValue < MODERATE_LIMIT) {

    status = "MODERATE";

    digitalWrite(YELLOW_LED, HIGH);

    tone(BUZZER, 1000, 500);

    SerialBT.println("WARNING");
    SerialBT.println("Moderate Smoke Detected");
    SerialBT.print("Gas = ");
    SerialBT.println(gasValue);
    SerialBT.println("Check Fireplace");

  }

  // ---------- DANGER ----------

  else {

    status = "DANGER";

    digitalWrite(RED_LED, HIGH);

    tone(BUZZER, 2000);

    SerialBT.println("DANGER !!");
    SerialBT.println("Smoke Level Critical");
    SerialBT.print("Gas = ");
    SerialBT.println(gasValue);
    SerialBT.println("Open Windows");
    SerialBT.println("Leave Room Immediately");

  }

  // Printing data in CSV format

  Serial.print(millis() / 1000);

  Serial.print(",");

  Serial.print(gasValue);

  Serial.print(",");

  Serial.print(temperature);

  Serial.print(",");

  Serial.print(humidity);

  Serial.print(",");

  Serial.println(status);

  delay(2000);

}
